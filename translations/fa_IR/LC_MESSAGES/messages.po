msgstr "❌ خطای ثبت‌نام: %(error)s"

msgid "❌ Your account is locked until %(lock_time)s due to failed attempts."
msgstr "❌ حساب شما به دلیل تلاش‌های ناموفق تا %(lock_time)s قفل شده است."

msgid "❌ Please verify your email before logging in. Check your inbox for the verification link."
msgstr "❌ لطفاً پیش از ورود، ایمیل خود را تأیید کنید. صندوق ورودی خود را برای لینک تأیید بررسی کنید."

msgid "✅ Password verified. Please enter your 2FA code."
msgstr "✅ رمز عبور تأیید شد. لطفاً کد احراز هویت دو مرحله‌ای خود را وارد کنید."

msgid "✅ Welcome!"
msgstr "✅ خوش آمدید!"

msgid "❌ Your account has been locked for 15 minutes due to too many failed attempts."
msgstr "❌ حساب شما به دلیل تلاش‌های ناموفق زیاد به مدت ۱۵ دقیقه قفل شد."

msgid "❌ Incorrect email or password. %(attempts)s more attempts before account is locked."
msgstr "❌ ایمیل یا رمز عبور اشتباه است. %(attempts)s تلاش دیگر پیش از قفل شدن حساب."

msgid "❌ Incorrect email or password."
msgstr "❌ ایمیل یا رمز عبور اشتباه است."

msgid "✅ Profile picture updated successfully."
msgstr "✅ عکس پروفایل با موفقیت به‌روز شد."

msgid "✅ Profile updated successfully."
msgstr "✅ پروفایل با موفقیت به‌روز شد."

msgid "❌ The current password is incorrect."
msgstr "❌ رمز عبور فعلی نادرست است."

msgid "❌ New password must be at least 8 characters long."
msgstr "❌ رمز عبور جدید باید حداقل ۸ کاراکتر باشد."

msgid "❌ New password and repeat password do not match."
msgstr "❌ رمز عبور جدید و تکرار آن مطابقت ندارند."

msgid "⚠️ New password must not be the same as previous password."
msgstr "⚠️ رمز عبور جدید نباید مشابه رمز قبلی باشد."

msgid "✅ Your password has been changed successfully."
msgstr "✅ رمز عبور شما با موفقیت تغییر یافت."

msgid "❌ An error occurred while changing the password. Please try again."
msgstr "❌ خطایی در تغییر رمز عبور رخ داد. لطفاً مجدداً تلاش کنید."

msgid "⚠️ Please check the confirmation checkbox to delete the account."
msgstr "⚠️ لطفاً برای حذف حساب، کادر تأیید را تیک بزنید."

msgid "🗑️ Your account has been successfully deleted. Thank you for your cooperation."
msgstr "🗑️ حساب شما با موفقیت حذف شد. از همکاری شما سپاسگزاریم."

msgid "❌ An error occurred while deleting the account. Please contact support."
msgstr "❌ خطایی در حذف حساب رخ داد. لطفاً با پشتیبانی تماس بگیرید."

msgid "👋 You have successfully logged out."
msgstr "👋 شما با موفقیت خارج شدید."

msgid "❌ This account is inactive."
msgstr "❌ این حساب غیرفعال است."

msgid "✅ You have already become a special user."
msgstr "✅ شما از قبل کاربر ویژه شده‌اید."

msgid "⚠️ Your request is under review by admin."
msgstr "⚠️ درخواست شما در حال بررسی توسط مدیریت است."

msgid "You are already a Premium member. Your documents have been verified."
msgstr "شما از قبل عضو ویژه هستید. مدارک شما تأیید شده‌اند."

msgid "You already have a pending verification request."
msgstr "شما از قبل یک درخواست تأیید در حال انتظار دارید."

msgid "The upgrade process has started. Please upload your documents."
msgstr "فرآیند ارتقا آغاز شد. لطفاً مدارک خود را آپلود کنید."

msgid "Please start the premium verification process first."
msgstr "لطفاً ابتدا فرآیند تأیید ویژه را آغاز کنید."

msgid "Your documents have been verified. You cannot modify them."
msgstr "مدارک شما تأیید شده‌اند و قابل تغییر نیستند."

msgid "Your documents are under review by admin."
msgstr "مدارک شما در حال بررسی توسط مدیریت است."

msgid "✅ Documents uploaded successfully."
msgstr "✅ مدارک با موفقیت آپلود شدند."

msgid "❌ No files were found to upload. Please select files and try again."
msgstr "❌ هیچ فایلی برای آپلود یافت نشد. لطفاً فایل‌ها را انتخاب و مجدداً تلاش کنید."

msgid "No verification request found."
msgstr "هیچ درخواست تأییدی یافت نشد."

msgid "Please upload your documents first."
msgstr "لطفاً ابتدا مدارک خود را آپلود کنید."

msgid "Payment receipt received. Reviewing..."
msgstr "رسید پرداخت دریافت شد. در حال بررسی..."

msgid "❌ You do not have permission to manage orders."
msgstr "❌ شما مجوز مدیریت سفارشات را ندارید."

msgid "❌ Please enter the product name."
msgstr "❌ لطفاً نام محصول را وارد کنید."

msgid "❌ Please select origin and destination."
msgstr "❌ لطفاً مبدأ و مقصد را انتخاب کنید."

msgid "❌ Invalid quantity or price."
msgstr "❌ مقدار یا قیمت نامعتبر است."

msgid "❌ The seller is invalid."
msgstr "❌ فروشنده نامعتبر است."

msgid "❌ The desired seller was not found."
msgstr "❌ فروشنده مورد نظر یافت نشد."

msgid "❌ The selected user is not a producer."
msgstr "❌ کاربر انتخاب‌شده تولیدکننده نیست."

msgid "✅ Order successfully placed."
msgstr "✅ سفارش با موفقیت ثبت شد."

msgid "❌ An error occurred while placing your order. Please try again."
msgstr "❌ خطایی در ثبت سفارش رخ داد. لطفاً مجدداً تلاش کنید."

msgid "❌ You can only cancel your own orders."
msgstr "❌ شما فقط می‌توانید سفارشات خود را لغو کنید."

msgid "🗑️ Order #%(order_id)s has been cancelled."
msgstr "🗑️ سفارش #%(order_id)s لغو شد."

msgid "⚠️ This order cannot be cancelled as it has already been processed."
msgstr "⚠️ این سفارش به دلیل پردازش شدن قابل لغو نیست."

msgid "✅ The order was confirmed and the notification was sent"
msgstr "✅ سفارش تأیید شد و اعلان ارسال گردید"

msgid "⚠️This order has already been approved or rejected."
msgstr "⚠️ این سفارش پیش‌تر تأیید یا رد شده است."

msgid "🗑️ Order #%(order_id)s rejected."
msgstr "🗑️ سفارش #%(order_id)s رد شد."

msgid "⚠️ This order has already changed status."
msgstr "⚠️ وضعیت این سفارش قبلاً تغییر کرده است."

msgid "❌ You can only update your own orders."
msgstr "❌ شما فقط می‌توانید سفارشات خود را به‌روز کنید."

msgid "✅ Order status updated to In Transit"
msgstr "✅ وضعیت سفارش به «در حال انتقال» به‌روز شد"

msgid "✅ Order marked as Delivered"
msgstr "✅ سفارش به عنوان «تحویل داده شده» علامت‌گذاری شد"

msgid "⚠️ Cannot update order status at this stage."
msgstr "⚠️ در این مرحله امکان به‌روزرسانی وضعیت سفارش وجود ندارد."

msgid "✅ All notifications marked as read"
msgstr "✅ تمام اعلان‌ها به عنوان خوانده‌شده علامت‌گذاری شدند"

msgid "❌ Limited access: Only special users can send messages."
msgstr "❌ دسترسی محدود: فقط کاربران ویژه می‌توانند پیام ارسال کنند."

msgid "❌ Access denied: Non-special users can only view messages from admin."
msgstr "❌ دسترسی رد شد: کاربران غیر ویژه فقط می‌توانند پیام‌های مدیریت را مشاهده کنند."

msgid "❌ This user is not special and you cannot chat with him/her."
msgstr "❌ این کاربر ویژه نیست و نمی‌توانید با او چت کنید."

msgid "✉️ Message sent."
msgstr "✉️ پیام ارسال شد."

msgid "⚠️ No admin found to contact."
msgstr "⚠️ مدیری برای تماس یافت نشد."

msgid "❌ Please enter a message."
msgstr "❌ لطفاً پیامی وارد کنید."

msgid "✅ Your message was sent to support."
msgstr "✅ پیام شما به پشتیبانی ارسال شد."

msgid "❌ Access is only allowed for special users."
msgstr "❌ دسترسی فقط برای کاربران ویژه مجاز است."

msgid "❌ Please enter a valid 7-digit ID (IMO)."
msgstr "❌ لطفاً یک شناسه ۷ رقمی معتبر (IMO) وارد کنید."

msgid "⚠️ Network unavailable. Showing demo data."
msgstr "⚠️ شبکه در دسترس نیست. نمایش داده‌های نمونه."

msgid "❌ No data found for this ship."
msgstr "❌ داده‌ای برای این کشتی یافت نشد."

msgid "❌ The request to the server was scheduled. Please try again."
msgstr "❌ درخواست به سرور زمان‌بندی شد. لطفاً مجدداً تلاش کنید."

msgid "❌ An error occurred with the ship tracking service."
msgstr "❌ خطایی در سرویس ردیابی کشتی رخ داد."

msgid "❌ The received data is invalid."
msgstr "❌ داده‌های دریافتی نامعتبر هستند."

msgid "❌ Only special users can access the map."
msgstr "❌ دسترسی به نقشه فقط برای کاربران ویژه مجاز است."

msgid "⚠️ No port data available."
msgstr "⚠️ داده‌ای از بنادر در دسترس نیست."

#: auth.py
msgid "❌ Please enter your mobile number in your profile first."
msgstr "❌ لطفاً ابتدا شماره موبایل خود را در پروفایل وارد کنید."

msgid "✅ Your mobile number has already been verified."
msgstr "✅ شماره موبایل شما پیش‌تر تأیید شده است."

msgid "New code sent."
msgstr "کد جدید ارسال شد."

msgid "❌ There was a problem sending the code."
msgstr "❌ مشکلی در ارسال کد رخ داد."

msgid "Please enter the code."
msgstr "لطفاً کد را وارد کنید."

msgid "✅ Mobile number successfully verified."
msgstr "✅ شماره موبایل با موفقیت تأیید شد."

msgid "❌ The code is invalid."
msgstr "❌ کد نامعتبر است."

msgid "A verification code has been sent to your number."
msgstr "یک کد تأیید به شماره شما ارسال شد."

msgid "Confirmation email sent."
msgstr "ایمیل تأیید ارسال شد."

msgid "❌ There was an error sending the email."
msgstr "❌ خطایی در ارسال ایمیل رخ داد."

msgid "❌ The link has expired."
msgstr "❌ لینک منقضی شده است."

msgid "❌ The link is invalid."
msgstr "❌ لینک نامعتبر است."

msgid "❌ This link is not for you."
msgstr "❌ این لینک متعلق به شما نیست."

msgid "❌ No request found."
msgstr "❌ هیچ درخواستی یافت نشد."

msgid "✅ Email has been verified."
msgstr "✅ ایمیل تأیید شد."

msgid "❌ Please enter your email."
msgstr "❌ لطفاً ایمیل خود را وارد کنید."

msgid "✅ If your email is registered in the system, a recovery link will be sent to you."
msgstr "✅ اگر ایمیل شما در سیستم ثبت شده باشد، لینک بازیابی برایتان ارسال خواهد شد."

msgid "❌ The recovery link is invalid or expired."
msgstr "❌ لینک بازیابی نامعتبر یا منقضی شده است."

msgid "❌ User not found."
msgstr "❌ کاربر یافت نشد."

msgid "❌ Password and repeat do not match."
msgstr "❌ رمز عبور و تکرار آن مطابقت ندارند."

msgid "⚠️ Two-factor authentication is already enabled."
msgstr "⚠️ احراز هویت دو مرحله‌ای از قبل فعال است."

msgid "❌ The information is incomplete."
msgstr "❌ اطلاعات ناقص است."

msgid "✅ Two-factor authentication enabled. Save backup codes!"
msgstr "✅ احراز هویت دو مرحله‌ای فعال شد. کدهای پشتیبان را ذخیره کنید!"

msgid "❌ The code entered is not valid."
msgstr "❌ کد وارد شده نامعتبر است."

msgid "⚠️ No backup codes found."
msgstr "⚠️ هیچ کد پشتیبانی یافت نشد."

msgid "⚠️ Two-factor authentication is not enabled."
msgstr "⚠️ احراز هویت دو مرحله‌ای فعال نیست."

msgid "✅ Two-factor authentication disabled."
msgstr "✅ احراز هویت دو مرحله‌ای غیرفعال شد."

msgid "❌ No pending login found. Please log in first."
msgstr "❌ هیچ ورود در انتظاری یافت نشد. لطفاً ابتدا وارد شوید."

msgid "✅ Welcome! Two-factor authentication successful."
msgstr "✅ خوش آمدید! احراز هویت دو مرحله‌ای موفقیت‌آمیز بود."

msgid "✅ Session successfully canceled."
msgstr "✅ نشست با موفقیت لغو شد."

msgid "❌ Session not found."
msgstr "❌ نشست یافت نشد."

msgid "✅ All sessions have been canceled."
msgstr "✅ تمام نشست‌ها لغو شدند."

#: permissions_routes.py & permissions.py
msgid "Profile for user %(username)s was automatically created."
msgstr "پروفایل برای کاربر %(username)s به صورت خودکار ایجاد شد."

msgid "Security error: Invalid CSRF token."
msgstr "خطای امنیتی: توکن CSRF نامعتبر است."

msgid "Permissions for user %(username)s updated successfully. (%(count)s active permissions)"
msgstr "دسترسی‌های کاربر %(username)s با موفقیت به‌روز شد. (%(count)s دسترسی فعال)"

msgid "Permissions for user %(username)s reverted to default."
msgstr "دسترسی‌های کاربر %(username)s به حالت پیش‌فرض بازگردانده شد."

msgid "User %(username)s profile created automatically."
msgstr "پروفایل کاربر %(username)s به صورت خودکار ایجاد شد."

msgid "Invalid permission."
msgstr "دسترسی نامعتبر است."

msgid "Permission %(perm)s granted to user %(username)s."
msgstr "دسترسی %(perm)s به کاربر %(username)s اعطا شد."

msgid "Permission %(perm)s already granted to user."
msgstr "دسترسی %(perm)s پیش‌تر به کاربر اعطا شده است."

msgid "Permission %(perm)s revoked from user %(username)s."
msgstr "دسترسی %(perm)s از کاربر %(username)s لغو شد."

msgid "Permission %(perm)s was not in user's permission list."
msgstr "دسترسی %(perm)s در لیست دسترسی‌های کاربر وجود نداشت."

msgid "You do not have permission to access this page."
msgstr "شما مجوز دسترسی به این صفحه را ندارید."

#: utils & email templates
msgid "No account found with this email."
msgstr "حسابی با این ایمیل یافت نشد."

msgid "✅ Your email is already verified."
msgstr "✅ ایمیل شما قبلاً تأیید شده است."

msgid "📧 New verification email sent! Please check your inbox."
msgstr "📧 ایمیل تأیید جدید ارسال شد! لطفاً صندوق ورودی خود را بررسی کنید."

msgid "⚠️ Failed to send email: %(error)s"
msgstr "⚠️ ارسال ایمیل ناموفق بود: %(error)s"

msgid "✅ Your email is already verified. You can login."
msgstr "✅ ایمیل شما قبلاً تأیید شده است. می‌توانید وارد شوید."

msgid "🎉 Email verified successfully! Welcome to Metisma."
msgstr "🎉 ایمیل با موفقیت تأیید شد! به متیسما خوش آمدید."